# Archi - Copy to .env and fill in

# Optional: base path for logs, data, workspace (default: repo root)
# ARCHI_ROOT=C:/Archi

# === OpenRouter API ===
# 1. Create account at https://openrouter.ai
# 2. (Optional) Add your xAI key in Settings for BYOK (first 1M requests/month free)
# 3. Generate API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-replace-with-your-key
# Default model: x-ai/grok-4.1-fast (hardcoded). Override here only if needed.
# Switchable at runtime via Discord: "switch to deepseek", "switch to auto", etc.
# Examples:
#   x-ai/grok-4.1-fast             — default (good all-rounder)
#   deepseek/deepseek-chat-v3-0324  — excellent coder, very cheap
#   openrouter/auto                 — auto-selects per prompt (unpredictable cost)
# OPENROUTER_MODEL=x-ai/grok-4.1-fast
# Optional: separate vision model (defaults to OPENROUTER_MODEL)
# OPENROUTER_VISION_MODEL=openrouter/auto
# Optional: app attribution headers for OpenRouter leaderboards
# OPENROUTER_APP_REFERER=https://github.com/archi-agent
# OPENROUTER_APP_TITLE=Archi

# === Direct Provider APIs (optional) ===
# Add any of these to route to a provider's own API instead of OpenRouter.
# Use via Discord: "switch to grok direct", "switch to claude direct", etc.
# XAI_API_KEY=                          # xAI Grok direct (https://console.x.ai)
# DEEPSEEK_API_KEY=                     # DeepSeek direct (https://platform.deepseek.com)
# ANTHROPIC_API_KEY=                    # Anthropic direct (https://console.anthropic.com)
# OPENAI_API_KEY=                       # OpenAI direct (https://platform.openai.com)
# MISTRAL_API_KEY=                      # Mistral direct (https://console.mistral.ai)
# Override base URLs only if using a custom endpoint (rarely needed):
# XAI_BASE_URL=https://api.x.ai/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gate C – Computer Use (optional)
# START_BUTTON_X=843           # px or fraction (e.g. 0.33)
# SKIP_API_VISION=1            # Disable API vision fallback
# DEBUG_CLICK=1                # Save annotated screenshot

# Discord bot (Gate G) - https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_OWNER_ID=your_discord_user_id

# Limits
# DAILY_BUDGET_USD=5.00
# LOG_LEVEL=INFO

# ARCHI_CONVERSATIONAL_WORD_LIMIT=25   # Max user words for conversational threshold (default 25)

# Image generation (SDXL) — auto-detects .safetensors in models/ if not set
# IMAGE_MODEL_PATH=models/illustriousRealismBy_v10VAE.safetensors

# Voice / TTS (Piper) — requires piper-tts installed and model in models/piper/
# ARCHI_VOICE_ENABLED=0                # Set to 1 to enable voice responses
# ARCHI_WHISPER_MODEL=base             # Whisper model size (tiny/base/small/medium/large)
# ARCHI_PIPER_VOICE=en_US-lessac-medium  # Piper voice name (default: en_US-lessac-medium)
