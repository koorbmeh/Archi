# Archi - Copy to .env and fill in

# Optional: base path for logs, data, workspace (default: repo root)
# ARCHI_ROOT=C:/Archi

# === OpenRouter API ===
# 1. Create account at https://openrouter.ai
# 2. (Optional) Add your xAI key in Settings for BYOK (first 1M requests/month free)
# 3. Generate API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-replace-with-your-key
# Default model: x-ai/grok-4.1-fast (hardcoded). Override here only if needed.
# Switchable at runtime via Discord: "switch to deepseek", "switch to auto", etc.
# Examples:
#   x-ai/grok-4.1-fast             — default (good all-rounder)
#   deepseek/deepseek-chat-v3-0324  — excellent coder, very cheap
#   openrouter/auto                 — auto-selects per prompt (unpredictable cost)
# OPENROUTER_MODEL=x-ai/grok-4.1-fast
# Optional: separate vision model (defaults to OPENROUTER_MODEL)
# OPENROUTER_VISION_MODEL=openrouter/auto
# Optional: app attribution headers for OpenRouter leaderboards
# OPENROUTER_APP_REFERER=https://github.com/archi-agent
# OPENROUTER_APP_TITLE=Archi

# === Direct Provider APIs (optional) ===
# Add any of these to route to a provider's own API instead of OpenRouter.
# Use via Discord: "switch to grok direct", "switch to claude direct", etc.
# XAI_API_KEY=                          # xAI Grok direct (https://console.x.ai)
# DEEPSEEK_API_KEY=                     # DeepSeek direct (https://platform.deepseek.com)
# ANTHROPIC_API_KEY=                    # Anthropic direct (https://console.anthropic.com)
# OPENAI_API_KEY=                       # OpenAI direct (https://platform.openai.com)
# MISTRAL_API_KEY=                      # Mistral direct (https://console.mistral.ai)
# Override base URLs only if using a custom endpoint (rarely needed):
# XAI_BASE_URL=https://api.x.ai/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gate C – Computer Use (optional)
# START_BUTTON_X=843           # px or fraction (e.g. 0.33)
# SKIP_API_VISION=1            # Disable API vision fallback
# DEBUG_CLICK=1                # Save annotated screenshot

# Discord bot (Gate G) - https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_OWNER_ID=your_discord_user_id

# SSL — set if you get certificate errors on Windows (e.g. corporate proxy, custom CA)
# Point to a PEM bundle. Common default: C:/path/to/cacert.pem
# SSL_CERT_FILE=

# Limits
# DAILY_BUDGET_USD=5.00
# LOG_LEVEL=INFO

# ARCHI_CONVERSATIONAL_WORD_LIMIT=25   # Max user words for conversational threshold (default 25)

# Image generation (SDXL) — auto-detects .safetensors in models/ if not set
# IMAGE_MODEL_PATH=models/illustriousRealismBy_v10VAE.safetensors

# MCP — GitHub MCP server (Phase 7)
# Required for GitHub integration (check issues, read repos, create PRs)
# Generate at: https://github.com/settings/tokens (fine-grained recommended)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_replace_with_your_token

# Email: Enable 2FA on Archi's Outlook account, then generate an App Password
# See: https://account.microsoft.com/security → Advanced security options → App passwords
ARCHI_EMAIL_ADDRESS=
ARCHI_EMAIL_APP_PASSWORD=

# Morning Digest — news + weather + calendar integrated automatically
# Optional: OpenWeatherMap for more detailed forecasts (free tier: 1000 calls/day)
# OPENWEATHER_API_KEY=                   # https://openweathermap.org/api (optional)
# Note: feedparser pip package required for RSS news feeds: pip install feedparser

# Calendar — ICS feed URLs (comma-separated). Works with Outlook, Google, Apple Calendar.
# Outlook: Settings → Calendar → Shared calendars → Publish a calendar → ICS link
# Google: Settings → Calendar → Integrate calendar → Secret address in iCal format
# ARCHI_CALENDAR_URLS=https://outlook.live.com/owa/calendar/...,https://calendar.google.com/...

# Content Pipeline — GitHub Blog (session 228)
# Create a GitHub Personal Access Token with repo permissions at:
# https://github.com/settings/tokens (classic token with "repo" scope)
# GITHUB_PAT=ghp_xxx
# GITHUB_BLOG_REPO=YourUsername/archi-blog    # owner/repo format

# Content Pipeline — Twitter/X (free tier: ~500 tweets/month, write-only)
# Create app at https://developer.x.com, enable OAuth 1.0a with Read+Write
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Content Pipeline — Reddit (free for personal bots)
# Create app at https://www.reddit.com/prefs/apps (script type)
# Use a dedicated bot account, not your main account
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# Content Pipeline — YouTube (free, OAuth 2.0)
# 1. Create project at https://console.cloud.google.com
# 2. Enable YouTube Data API v3
# 3. Create OAuth 2.0 Desktop credentials → get client ID + secret
# 4. Set YOUTUBE_CLIENT_ID and YOUTUBE_CLIENT_SECRET below
# 5. Run: python -c "from dotenv import load_dotenv; load_dotenv(); from src.tools.content_creator import youtube_authenticate; print(youtube_authenticate())"
#    (Opens browser, you grant access, it captures the token automatically)
# 6. Copy the refresh_token below
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# --- Meta Graph API (Facebook Pages + Instagram) ---
# 1. Go to https://developers.facebook.com → Create App (Business type)
# 2. Add "Facebook Login for Business" product
# 3. Request permissions: pages_manage_posts, pages_read_engagement,
#    instagram_basic, instagram_content_publish (for IG)
# 4. Get a Page Access Token via Graph API Explorer (convert to long-lived)
# 5. Find your Page ID at: https://www.facebook.com/<your-page>/about
# 6. For Instagram: link IG Business account to the Page, then get the
#    IG account ID via: GET /{page-id}?fields=instagram_business_account
# META_PAGE_ACCESS_TOKEN=
# META_PAGE_ID=
# META_INSTAGRAM_ACCOUNT_ID=

# Voice / TTS (Piper) — requires piper-tts installed and model in models/piper/
# ARCHI_VOICE_ENABLED=0                # Set to 1 to enable voice responses
# ARCHI_WHISPER_MODEL=base             # Whisper model size (tiny/base/small/medium/large)
# ARCHI_PIPER_VOICE=en_US-lessac-medium  # Piper voice name (default: en_US-lessac-medium)
